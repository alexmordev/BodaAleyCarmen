# === Base de datos MySQL (Hostinger) ===
# hPanel -> Bases de datos MySQL. Para conexion remota (correr migraciones desde
# tu maquina) hay que habilitar "Remote MySQL" y autorizar tu IP.
DB_HOST=localhost
DB_PORT=3306
DB_USER=u123456789_boda
DB_PASSWORD=cambia-esto
DB_NAME=u123456789_boda
# Pon DB_SSL=true solo si tu proveedor exige TLS (Hostinger compartido normalmente no).
DB_SSL=false

# URL publica del sitio (para construir los enlaces ?i=<token> que se reparten).
NEXT_PUBLIC_SITE_URL=https://aleycarmen.com
